generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  password         String
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt

  @@map("admin")
}

model Blog {
  id               String    @id @default(uuid())
  title             String
  content            String    @unique
  
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt

}



