generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  password         String
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt

  @@map("admin")
}

model Blog {
  id          String   @id @default(uuid())
  title       String 
  slug        String   @unique    // : if the blog title is My First Post, the slug might be my-first-post, and you can use it in URLs like /blog/my-first-post.
  excerpt     String?  @db.Text
  content     String   @db.LongText
  coverImage  String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blogs")
}



